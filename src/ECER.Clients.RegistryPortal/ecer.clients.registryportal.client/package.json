{
  "name": "ecer.clients.registryportal.client",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && npm run lint && npm run type-check && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "gen-api": "npx openapicmd typegen http://localhost:5120/swagger/v1/swagger.json > src/types/openapi.d.ts && npm run lint-fix",
    "cy-open": "cypress open",
    "cy-run": "cypress run",
    "e2e-chrome": "cypress run --browser chrome --headed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "validate-colors": "tsx scripts/validate-colors.ts"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "oidc-client-ts": "3.4.1",
    "openapi-client-axios": "^7.9.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "uuid": "^13.0.2",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vuetify": "4.0.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tsconfig/node18": "^18.2.6",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.18.0",
    "cypress-file-upload": "^5.0.8",
    "eslint": "^9.39.4",
    "eslint-plugin-chai-friendly": "^1.2.1",
    "eslint-plugin-cypress": "^5.3.0",
    "eslint-plugin-mocha": "^11.3.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "openapicmd": "^2.9.2",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
